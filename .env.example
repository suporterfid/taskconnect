APP_NAME=TaskConnect
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_PORT=8080
APP_VERSION=1.2.0

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=taskconnect
DB_USERNAME=taskconnect
DB_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=localhost
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:8080,localhost:5173,127.0.0.1,127.0.0.1:8080,127.0.0.1:5173

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@taskconnect.local"
MAIL_FROM_NAME="${APP_NAME}"
MAILPIT_UI_PORT=8025
MAILPIT_SMTP_PORT=1025

RECEIVER_URL=http://receiver:8080
RECEIVER_PORT=8090
VITE_PORT=5173

VITE_APP_NAME="${APP_NAME}"

# Scheduler / outbound / retention (platform defaults)
SCHEDULER_CLAIM_BATCH=20
SCHEDULER_RETRY_BATCH=20
SCHEDULER_CLAIM_TTL_MINUTES=10
SCHEDULER_TARGET_DURATION_SECONDS=45
SCHEDULER_BUDGET_SAFETY_MARGIN_SECONDS=5
SCHEDULER_CLAIM_CHUNK=5
# v1 Extension R4 — task type governance (Q4 shared-hosting defaults)
TASK_TYPE_GLOBAL_INFLIGHT=4
TASK_TYPE_CONVERT_CAP=2
TASK_TYPE_CRAWL_CAP=1
TASK_TYPE_INDEX_CAP=2
TASK_TYPE_REMINDER_CAP=4
TASK_TYPE_PUBLISH_CAP=1
OUTBOUND_CONNECT_TIMEOUT=5
OUTBOUND_TOTAL_TIMEOUT=15
OUTBOUND_RESPONSE_BODY_LIMIT=65536
OUTBOUND_REQUEST_BODY_LIMIT=65536
OUTBOUND_REDIRECT_LIMIT=3
OUTBOUND_ALLOWED_PORTS=80,443
OUTBOUND_ALLOW_HTTP=false
OUTBOUND_USER_AGENT=OpenHttpScheduler/1.1
OUTBOUND_PLATFORM_ALLOW_HOSTS=
OUTBOUND_API_ALLOW_HOSTS=
OUTBOUND_TESTING_ALLOW_HOSTS=receiver
# Profile limit stubs (R7); public-crawl / api override global timeouts when set
# OUTBOUND_PUBLIC_CRAWL_REDIRECT_LIMIT=
# OUTBOUND_API_RESPONSE_BODY_LIMIT=

RETENTION_PAYLOAD_SNAPSHOTS_DAYS=30
RETENTION_ATTEMPT_METADATA_DAYS=180
RETENTION_RUN_SUMMARY_DAYS=365
RETENTION_AUDIT_LOGS_DAYS=365
# Enqueue Idempotency-Key TTL (hours). Alias of RETENTION_API_IDEMPOTENCY_HOURS.
IDEMPOTENCY_ENQUEUE_TTL_HOURS=24
RETENTION_API_IDEMPOTENCY_HOURS=24
RETENTION_SYSTEM_HEARTBEAT_DAYS=30
RETENTION_DEAD_RUNS_DAYS=30

# v1 Extension R8 — GrandpaSSOn delegated auth (placeholders; enable when #26 scopes ready)
GRANDPASSON_OUTBOUND_ENABLED=false
GRANDPASSON_INBOUND_ENABLED=false
GRANDPASSON_BASE_URL=
GRANDPASSON_CLIENT_ID=
GRANDPASSON_CLIENT_SECRET=
GRANDPASSON_TOKEN_URL=
GRANDPASSON_INTROSPECT_URL=
GRANDPASSON_CALLBACK_SCOPE=tasks:callback
GRANDPASSON_WRITE_SCOPE=tasks:write
GRANDPASSON_TOKEN_REFRESH_SKEW_SECONDS=60
TC_CALLBACK_HMAC_SECRET=
TC_CALLBACK_MAX_SKEW_SECONDS=300

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME="Platform Admin"

# Opt-in only — never commit mirror URLs
# COMPOSER_PACKAGIST_URL=
